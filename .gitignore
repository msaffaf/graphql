# Dependencies — never commit these. They contain platform-specific native
# binaries (e.g. @esbuild/win32-x64) and lose their executable bit on Windows,
# which breaks Linux CI/deploy builds with "exited with 126".
node_modules/

# Build output — regenerated by `npm run build` on the deploy runner
dist/

# Vite cache
.vite/

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
